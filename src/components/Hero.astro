---
// Hero — 轨道圆环 + 装饰色块 + 真实资料
---

<section id="home" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-12 md:mt-40 md:mb-12 py-24 flex flex-wrap-reverse md:flex-nowrap items-center justify-center gap-12">

  <div class="flex flex-col items-start gap-4 flex-shrink-0">
    <p class="text-lg font-bold text-slate-600">你好，我是</p>
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight">
      <span class="text-brand-500">如从</span>
    </h1>
    <p class="text-xl text-slate-500">测试开发 · 前端全栈</p>
    <div class="h-8 overflow-hidden mt-2">
      <p id="role-text" class="text-lg text-brand-500 font-semibold">测试开发工程师</p>
    </div>
    <!-- 学校信息 -->
    <div class="flex items-center gap-2 mt-3 text-slate-400 text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
      <span>武汉城市学院 · 软件工程 · 2026届 · 专业前5%</span>
    </div>
  </div>

  <!-- 3D 卡片 + Orbit -->
  <div class="relative w-[400px] h-[400px] flex items-center justify-center flex-shrink-0">

    <!-- Orbit 引导圆环 (仿 qzq.at SVG circle) -->
    <div class="orbit-ring" style="width: 300px; height: 300px; left: 50%; top: 50%; margin-left: -150px; margin-top: -150px;"></div>
    <div class="orbit-ring" style="width: 350px; height: 350px; left: 50%; top: 50%; margin-left: -175px; margin-top: -175px;"></div>

    <!-- 3D 卡片 -->
    <div class="card-3d-wrap">
      <div id="hero-card" class="card-3d card-light p-8">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center text-3xl font-bold text-white mb-4 shadow-lg shadow-brand-200 pulse-anim">
            如
          </div>
          <p class="text-sm text-slate-400">软件工程 · 2026</p>
          <p class="text-xs text-slate-300 mt-1">Python · 测试开发 · 前端</p>
        </div>
      </div>
    </div>

    <!-- 装饰色块 (仿 qzq.at) -->
    <div class="absolute w-16 h-16 bg-brand-400/20 rounded-full -left-4 -bottom-4 blur-sm pointer-events-none"></div>

    <!-- Orbit 轨道元素 -->
    {[
      { radius: 150, duration: 10, delay: -20, size: 46, color: "#61DAFB", label: "JS" },
      { radius: 150, duration: 20, delay: -20, size: 40, color: "#3178C6", label: "Py" },
      { radius: 150, duration: 16, delay: -15, size: 32, color: "#F05032", label: "Git" },
      { radius: 175, duration: 9, delay: -20, size: 100, color: "#F97316", label: "Node" },
    ].map(o => (
      <div class="absolute orbit-anim flex items-center justify-center rounded-full bg-transparent -z-10"
           style={{ width: o.size+'px', height: o.size+'px', '--radius': o.radius, '--duration': o.duration, '--delay': o.delay, left: '50%', top: '50%', marginLeft: (-o.size/2)+'px', marginTop: (-o.size/2)+'px' }}>
        <div class="flex items-center justify-center rounded-full bg-white shadow-lg"
             style={{ width: o.size+'px', height: o.size+'px', border: o.size>60?'none':`2px solid ${o.color}` }}>
          <span class="font-bold" style={{ color: o.color, fontSize: o.size>60?'14px':'10px' }}>{o.size>60?'Node.js':o.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const roles = ["测试开发工程师", "前端开发者", "全栈开发者", "终身学习者"];
  let ri = 0;
  const rt = document.getElementById('role-text');
  setInterval(() => {
    ri = (ri + 1) % roles.length;
    if (rt) { rt.style.opacity = '0'; rt.style.transform = 'translateY(-10px)';
      setTimeout(() => { rt.textContent = roles[ri]; rt.style.opacity = '1'; rt.style.transform = 'translateY(0)'; }, 200); }
  }, 3000);
  // 3D 追踪
  const card = document.getElementById('hero-card');
  if (card) {
    const wrap = card.closest('.card-3d-wrap');
    wrap.addEventListener('mousemove', (e) => {
      const r = wrap.getBoundingClientRect();
      card.style.transform = `rotateX(${((e.clientY-r.top)/r.height-0.5)*-20}deg) rotateY(${((e.clientX-r.left)/r.width-0.5)*20}deg)`;
    });
    wrap.addEventListener('mouseleave', () => { card.style.transform = 'rotateX(0deg) rotateY(0deg)'; });
  }
</script>
