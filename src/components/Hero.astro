---
// Hero — 轨道圆环 + 3D证件照卡片
const awards = "国家奖学金 · 国家励志奖学金 · 全国大学生计算机设计大赛 AI 组省级三等奖 · 专业一等奖学金";
const roles = ["测试开发工程师", "Vibe coder", "Prompt Engineer", "自动化测试工程师", "终身学习者"];

const bubbles = [
  { radius: 170, phi: 8,   speed: 10, startTheta: 22,  color: "#3776AB", label: "PyTest",       icon: "test",  tilt: "rotateX(20deg) rotateY(-15deg)" },
  { radius: 190, phi: 40,  speed: 10, startTheta: 120, color: "#F97316", label: "ADB",          icon: "mobile",tilt: "rotateX(15deg) rotateY(10deg)" },
  { radius: 210, phi: 72,  speed: 10, startTheta: 310, color: "#84CC16", label: "Apifox",       icon: "api",   tilt: "rotateX(-10deg) rotateY(20deg)" },
  { radius: 200, phi: 100, speed: 10, startTheta: 195, color: "#4B8BBE", label: "Python",       icon: "code",  tilt: "rotateX(-5deg) rotateY(25deg)" },
  { radius: 180, phi: 128, speed: 10, startTheta: 65,  color: "#F05032", label: "Git",          icon: "git",   tilt: "rotateX(-8deg) rotateY(-20deg)" },
  { radius: 220, phi: 90,  speed: 10, startTheta: 260, color: "#6366F1", label: "uiautomator2", icon: "robot", tilt: "rotateX(-20deg) rotateY(-10deg)" },
  { radius: 230, phi: 165, speed: 10, startTheta: 345, color: "#0EA5E9", label: "CANOE",        icon: "car",   tilt: "rotateX(12deg) rotateY(-25deg)" },
  { radius: 190, phi: 90,  speed: 10, startTheta: 80,  color: "#7C3AED", label: "AI Agent",     icon: "ai",   tilt: "rotateX(22deg) rotateY(-12deg)" },
];
---

<section id="home" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-6 md:my-12 md:mt-40 md:mb-12 py-12 md:py-24 flex flex-col-reverse md:flex-row md:flex-nowrap items-center justify-center gap-8 md:gap-12">

  <div class="flex flex-col items-start gap-3 md:gap-4 flex-shrink-0 w-full md:w-auto">
    <p class="text-base md:text-lg font-semibold text-slate-500 tracking-wide">你好，我是</p>
    <h1 class="font-fantasy text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight">
      <!-- 字母逐字渐入 -->
      <span class="text-brand-500 inline-block">
        {("如从").split('').map((c, i) => (
          <span class="char-blur-in" style={`animation-delay: ${i * 0.15}s`}>{c}</span>
        ))}
      </span>
    </h1>
    <p class="text-lg md:text-xl text-slate-500 font-light">测试开发 <span class="text-brand-300 mx-1">·</span> <a href="#contact" class="text-brand-500 hover:text-brand-600 transition-colors">Vibe Coder</a></p>
    <div class="h-7 md:h-8 overflow-hidden mt-2">
      <p id="role-text" class="text-lg md:text-xl text-brand-500 font-semibold tabular-nums">测试开发工程师</p>
    </div>

    <!-- 教育背景卡片（精简装饰） -->
    <div class="card-white p-3 sm:p-4 md:p-5 mt-3 md:mt-4 reveal w-full md:w-auto">
      <div class="flex items-center gap-2 sm:gap-3">
        <div class="w-8 h-8 sm:w-9 sm:h-9 md:w-10 md:h-10 lg:w-11 lg:h-11 rounded-xl bg-brand-100 flex items-center justify-center flex-shrink-0">
          <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 md:w-4.5 md:h-4.5 lg:w-5 lg:h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-slate-800 font-semibold text-[12px] sm:text-[13px] md:text-sm">武汉城市学院 · 软件工程 · 2026届</p>
          <p class="text-slate-400 text-[10px] sm:text-[11px] md:text-xs">专业前5% · 本科</p>
        </div>
      </div>
      <div class="mt-2.5 sm:mt-3 pt-2.5 sm:pt-3 border-t border-slate-100">
        <p class="text-slate-400 text-[9px] sm:text-[10px] md:text-[11px] lg:text-xs leading-relaxed tracking-wide break-words">{awards}</p>
      </div>
    </div>
  </div>

  <!-- 3D 环绕场景 -->
  <div class="orbit-scene">
    <!-- 轨道圆环（保留 4 个精简） -->
    <div class="orbit-rings">
      <div class="orbit-ring orbit-ring-glow" style="--size: 260px; --size-md: 340px; transform: rotateX(20deg) rotateY(-10deg);"></div>
      <div class="orbit-ring" style="--size: 300px; --size-md: 380px; border-width: 2px; transform: rotateX(10deg) rotateY(-5deg);"></div>
      <div class="orbit-ring orbit-ring-dashed" style="--size: 350px; --size-md: 430px; transform: rotateX(-20deg) rotateY(10deg);"></div>
      <div class="orbit-ring orbit-ring-gradient orbit-ring-pulse" style="--size: 400px; --size-md: 480px; transform: rotateX(5deg) rotateY(-15deg);"></div>
    </div>

    <!-- 气泡轨道 -->
    <div class="orbit-bubbles-container">
      {bubbles.map((o, i) => (
        <div 
          class="orbit-bubble-wrap"
          data-radius={o.radius}
          data-phi={o.phi}
          data-speed={o.speed}
          data-start-theta={o.startTheta}
          style={`--radius: ${o.radius}px; --radius-sm: ${Math.round(o.radius * 0.7)}px; --phi: ${o.phi}deg; --speed: ${o.speed}s; --start-theta: ${o.startTheta}deg; --delay: ${i * -0.5}s;`}
        >
          <div 
            class="orbit-bubble-inner"
            style={`border-color: ${o.color}; --tilt: ${o.tilt}; box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 0 18px ${o.color}40, 0 4px 12px rgba(0,0,0,0.06);`}
          >
            {o.icon === 'test' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>}
            {o.icon === 'code' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>}
            {o.icon === 'mobile' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>}
            {o.icon === 'robot' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>}
            {o.icon === 'git' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>}
            {o.icon === 'ai' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>}
            {o.icon === 'car' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17h8M8 17v4h8v-4M8 17H5a2 2 0 01-2-2V7c0-1.1.9-2 2-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3"/></svg>}
            {o.icon === 'api' && <svg class="w-3.5 h-3.5 md:w-4 md:h-4" style={`color: ${o.color}; filter: drop-shadow(0 0 6px ${o.color}60);`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>}
            <span class="font-medium whitespace-nowrap" style={`color: ${o.color}; font-size: 10px; --font-md: 12px; text-shadow: 0 0 8px ${o.color}60;`}>{o.label}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- 3D 立体证件照卡片 -->
    <div class="card-3d-wrap orbit-card-layer">
      <div id="hero-card" class="card-3d hero-photo-card">
        <div class="photo-frame">
          <img src="/avatar.jpg" alt="如从证件照" class="w-full h-full object-cover object-top" />
        </div>
        <div class="photo-info">
          <p class="text-sm font-bold text-slate-700">如从</p>
          <p class="text-[11px] text-slate-400 mt-0.5">软件工程 · 2026届</p>
          <p class="text-[10px] text-slate-300 mt-1">Python · 测试开发</p>
        </div>
      </div>
    </div>

    <!-- 进度指示条 -->
    <div class="orbit-progress">
      <div id="orbit-progress-bar" class="orbit-progress-bar"></div>
    </div>
  </div>
</section>

<script>
  const roles = ["测试开发工程师", "Vibe coder", "Prompt Engineer", "自动化测试工程师", "终身学习者"];
  let ri = 0;
  const rt = document.getElementById('role-text');
  setInterval(() => {
    ri = (ri + 1) % roles.length;
    if (rt) { rt.style.opacity = '0'; rt.style.transform = 'translateY(-10px)';
      setTimeout(() => { rt.textContent = roles[ri]; rt.style.opacity = '1'; rt.style.transform = 'translateY(0)'; }, 200); }
  }, 3000);

  // 3D 追踪 - 立体证件照卡片（移动端禁用）
  const card = document.getElementById('hero-card');
  if (card && window.innerWidth >= 768) {
    const wrap = card.closest('.card-3d-wrap');
    let ticking = false;
    wrap.addEventListener('mousemove', (e) => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const r = wrap.getBoundingClientRect();
        const x = ((e.clientX - r.left) / r.width - 0.5);
        const y = ((e.clientY - r.top) / r.height - 0.5);
        card.style.transform = `perspective(800px) rotateY(${-8 + x * 16}deg) rotateX(${5 - y * 10}deg)`;
        ticking = false;
      });
    });
    wrap.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(800px) rotateY(-8deg) rotateX(5deg)';
    });
  }

  // ---- 气泡动画 - 单 rAF 循环（性能优化）----
  const bubbleWraps = document.querySelectorAll(".orbit-bubble-wrap");
  const isMobile = () => window.innerWidth < 768;

  const bubblesData = [];
  bubbleWraps.forEach((wrap) => {
    const radiusFull = parseFloat(wrap.dataset.radius);
    const radiusSm = parseFloat(getComputedStyle(wrap).getPropertyValue('--radius-sm')) || radiusFull * 0.7;
    const phiDeg = parseFloat(wrap.dataset.phi);
    const speed = parseFloat(wrap.dataset.speed);
    const startTheta = parseFloat(wrap.dataset.startTheta);

    bubblesData.push({
      wrap,
      radiusFull,
      radiusSm,
      phiDeg,
      phiRad: phiDeg * Math.PI / 180,
      speed,
      theta: startTheta,
      paused: false,
      dragging: false,
      dragOffsetX: 0, dragOffsetY: 0,
      returnAnimId: null,
      inner: wrap.querySelector(".orbit-bubble-inner"),
    });
  });

  const updateAllRadii = () => {
    const mobile = isMobile();
    bubblesData.forEach(b => { b.currentRadius = mobile ? b.radiusSm : b.radiusFull; });
  };
  updateAllRadii();
  window.addEventListener('resize', updateAllRadii);

  // ---- 拖拽事件（每个气泡独立）----
  bubblesData.forEach((b) => {
    const { wrap } = b;
    function onPointerDown(e) {
      b.paused = true;
      b.dragging = true;
      if (b.returnAnimId) { cancelAnimationFrame(b.returnAnimId); b.returnAnimId = null; }
      resetProgress();
      wrap.style.transition = "none";
      const rect = wrap.getBoundingClientRect();
      b.dragOffsetX = e.clientX - (rect.left + rect.width / 2);
      b.dragOffsetY = e.clientY - (rect.top + rect.height / 2);
      wrap.style.zIndex = "999";
      wrap.style.filter = "drop-shadow(0 12px 32px rgba(0,0,0,0.2))";
      document.addEventListener("pointermove", onPointerMove, { passive: false });
      document.addEventListener("pointerup", onPointerUp);
    }
    function onPointerMove(e) {
      if (!b.dragging) return;
      e.preventDefault();
      const scene = wrap.closest(".orbit-scene");
      const sr = scene.getBoundingClientRect();
      const nx = e.clientX - sr.left - sr.width / 2 - b.dragOffsetX;
      const ny = e.clientY - sr.top - sr.height / 2 - b.dragOffsetY;
      wrap.style.transform = `translate3d(calc(-50% + ${nx}px), calc(-50% + ${ny}px), 120px) scale(1.15)`;
      wrap.style.opacity = "1";
    }
    function onPointerUp(e) {
      b.dragging = false;
      document.removeEventListener("pointermove", onPointerMove);
      document.removeEventListener("pointerup", onPointerUp);
      const scene = wrap.closest(".orbit-scene");
      const sr = scene.getBoundingClientRect();
      const cx = e.clientX - sr.left - sr.width / 2;
      const cy = e.clientY - sr.top - sr.height / 2;
      const rawAngle = Math.atan2(cy, cx) * 180 / Math.PI;
      b.theta = ((rawAngle % 360) + 360) % 360;

      let progress = 0;
      const startCx = cx, startCy = cy, startZ = 120, startScale = 1.15;
      function returnAnim() {
        progress += 0.04;
        if (progress >= 1) {
          progress = 1;
          b.returnAnimId = null;
          wrap.style.transition = "";
          wrap.style.zIndex = "";
          wrap.style.filter = "";
          wrap.style.opacity = "";
          b.paused = false;
          return;
        }
        const t = 1 - Math.pow(1 - progress, 3);
        wrap.style.transform = `translate3d(calc(-50% + ${startCx * (1 - t)}px), calc(-50% + ${startCy * (1 - t)}px), ${startZ * (1 - t)}px) scale(${1 + (startScale - 1) * (1 - t)})`;
        wrap.style.opacity = `${1 - (1 - t) * 0.3}`;
        b.returnAnimId = requestAnimationFrame(returnAnim);
      }
      b.returnAnimId = requestAnimationFrame(returnAnim);
    }
    wrap.addEventListener("pointerdown", onPointerDown);
    wrap.addEventListener("mouseenter", () => { if (!b.dragging) b.paused = true; });
    wrap.addEventListener("mouseleave", () => { if (!b.dragging) b.paused = false; });
  });

  // ==========================================
  // 进度条 + 注意力监听 统一调度
  // ==========================================
  const progressBar = document.getElementById('orbit-progress-bar');
  const progressWrap = progressBar?.parentElement;
  const orbitScene = document.querySelector('.orbit-scene');

  const ANIM_RUN = 20000;   // 环绕 20 秒
  const ANIM_PAUSE = 5000;  // 暂停 5 秒
  let progressPercent = 0;  // 0→100 环绕中 / 100→0 暂停中
  let animActive = true;    // true=环绕 / false=暂停
  let isVisible = true;     // 场景在视口 + 页面激活

  // ---- 可见性：IntersectionObserver (50% 可见才算) + Page Visibility ----
  if (orbitScene && 'IntersectionObserver' in window) {
    new IntersectionObserver(
      (entries) => {
        const inView = entries[0].isIntersecting;
        if (!inView && animActive) {
          animActive = false;
          if (progressBar) progressBar.style.transition = 'width 0.8s ease';
        }
        // 回到视野时在 animateAll 里自动恢复
      },
      { threshold: 0.5 }
    ).observe(orbitScene);
  }

  document.addEventListener('visibilitychange', () => {
    if (document.hidden && animActive) {
      animActive = false;
      if (progressBar) progressBar.style.transition = 'width 0.8s ease';
    }
  });

  function checkVisibility() {
    if (!orbitScene) { isVisible = !document.hidden; return; }
    const r = orbitScene.getBoundingClientRect();
    const vh = window.innerHeight;
    const vw = window.innerWidth;
    // 场景中心必须在视口内，且至少 30% 面积可见
    const cx = r.left + r.width / 2;
    const cy = r.top + r.height / 2;
    const centerInView = cx > 0 && cx < vw && cy > 0 && cy < vh;
    const visibleH = Math.min(r.bottom, vh) - Math.max(r.top, 0);
    const ratio = visibleH > 0 ? visibleH / r.height : 0;
    isVisible = centerInView && ratio > 0.3 && !document.hidden;

    if (!isVisible && animActive) {
      animActive = false;
      if (progressBar) progressBar.style.transition = 'width 0.8s ease';
    }
  }

  // ---- 用户交互：拖拽任一气泡 → 重置进度条、恢复环绕 ----
  function resetProgress() {
    progressPercent = 0;
    animActive = true;
    if (progressBar) {
      progressBar.style.transition = 'width 0.3s linear';
      progressBar.style.width = '0%';
    }
    if (progressWrap) progressWrap.classList.add('visible');
    lastTime = performance.now();
  }

  // ---- 合并后的单 rAF 循环 ----
  let lastTime = performance.now();

  function animateAll(currentTime) {
    checkVisibility();

    // 拖拽中？重置进度
    const anyDragging = bubblesData.some(b => b.dragging);
    if (anyDragging) resetProgress();

    // 场景不可见 → 暂停环绕，进度条保持
    if (!isVisible) {
      lastTime = performance.now();
      requestAnimationFrame(animateAll);
      return;
    }

    const dt = Math.min((currentTime - lastTime) / 1000, 0.1);
    lastTime = currentTime;

    // ---- 进度条驱动 ----
    if (animActive) {
      progressPercent += (100 / (ANIM_RUN / 1000)) * dt;
      if (progressPercent >= 100) {
        progressPercent = 100;
        animActive = false;
        if (progressBar) progressBar.style.transition = 'width 0.8s ease';
      }
    } else {
      progressPercent -= (100 / (ANIM_PAUSE / 1000)) * dt;
      if (progressPercent <= 0) {
        progressPercent = 0;
        animActive = true;
        if (progressBar) {
          progressBar.style.transition = 'width 0.3s linear';
        }
        if (progressWrap) progressWrap.classList.add('visible');
      }
    }

    // 更新进度条
    if (progressBar) {
      progressBar.style.width = progressPercent + '%';
    }
    if (progressWrap) {
      if (animActive) {
        progressWrap.classList.add('visible');
        progressWrap.classList.remove('paused');
      } else {
        progressWrap.classList.add('paused');
        // 进度条回 0 时隐藏
        if (progressPercent <= 1) progressWrap.classList.remove('visible');
      }
    }

    // ---- 气泡环绕 ----
    if (!animActive) {
      requestAnimationFrame(animateAll);
      return;
    }

    for (let i = 0; i < bubblesData.length; i++) {
      const b = bubblesData[i];
      if (b.dragging) continue;
      if (!b.paused) {
        b.theta += (360 / b.speed) * dt;
        if (b.theta >= 360) b.theta -= 360;
      }
      const thetaRad = b.theta * Math.PI / 180;
      const r = b.currentRadius;
      const x = r * Math.sin(b.phiRad) * Math.sin(thetaRad);
      const y = -r * Math.cos(b.phiRad);
      const smooth = (Math.cos(thetaRad) + 1) / 2;

      const zVal = -100 + smooth * 180;
      const scaleVal = 0.75 + smooth * 0.35;

      b.wrap.style.transform = `translate3d(calc(-50% + ${x}px), calc(-50% + ${y}px), ${zVal}px) scale(${scaleVal})`;
      b.wrap.style.zIndex = String(Math.round(10 + smooth * 15));
      b.wrap.style.opacity = String(0.55 + smooth * 0.45);
    }
    requestAnimationFrame(animateAll);
  }
  requestAnimationFrame(animateAll);
