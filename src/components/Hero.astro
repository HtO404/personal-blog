---
// Hero — qzq.at 正版 3D Orbit 动画
const navItems = ["前端开发工程师", "全栈开发者", "技术博主", "终身学习者"];
---


<section id="home" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-12 md:mt-40 md:mb-12 py-24 flex flex-wrap-reverse md:flex-nowrap items-center justify-center gap-12">

  <!-- 左侧：文字区域 -->
  <div class="flex flex-col items-start gap-4 flex-shrink-0">
    <p class="text-lg font-bold text-slate-600">你好，我是</p>
    
    <!-- Coda 字体大标题 (同 qzq.at: 60px orange) -->
    <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight">
      <span class="text-brand-500">如从</span>
    </h1>
    
    <p class="text-xl text-slate-500">—— 用代码构建美好体验</p>
    
    <!-- 角色轮播 -->
    <div class="h-8 overflow-hidden mt-2">
      <p id="role-text" class="text-lg text-brand-500 font-semibold">前端开发工程师</p>
    </div>
  </div>

  <!-- 右侧：Orbit 3D 卡片 (完全仿 qzq.at) -->
  <div class="relative w-[350px] h-[350px] md:w-[400px] md:h-[400px] flex items-center justify-center flex-shrink-0">

    <!-- 3D 中心卡片 -->
    <div class="card-3d-wrap">
      <div id="hero-card" class="card-3d card-light p-8">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto rounded-2xl bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center text-3xl font-bold text-white mb-4 shadow-lg shadow-brand-200 pulse-anim">
            如
          </div>
          <p class="text-sm text-slate-400">前端开发 · {new Date().getFullYear()}</p>
          <p class="text-xs text-slate-300 mt-1">React / Vue / Node.js</p>
        </div>
      </div>
    </div>

    <!-- 4个轨道环 （正版 orbit 动画：rotate→translateY→rotate） -->
    {[
      { radius: 150, duration: 10, delay: -20, size: 50, color: "#61DAFB", label: "React" },
      { radius: 150, duration: 20, delay: -20, size: 48, color: "#3178C6", label: "TS" },
      { radius: 150, duration: 16, delay: -15, size: 32, color: "#F05032", label: "Git" },
      { radius: 175, duration: 9, delay: -20, size: 120, color: "#339933", label: "Node" },
    ].map((o, i) => (
      <div 
        class="absolute orbit-anim flex items-center justify-center rounded-full bg-transparent -z-10"
        style={{
          width: `${o.size}px`,
          height: `${o.size}px`,
          '--radius': o.radius,
          '--duration': o.duration,
          '--delay': o.delay,
          left: '50%',
          top: '50%',
          marginLeft: `${-o.size / 2}px`,
          marginTop: `${-o.size / 2}px`,
        }}
      >
        <div 
          class={`flex items-center justify-center rounded-full ${o.size > 60 ? 'bg-white/80' : 'bg-white'} shadow-lg`}
          style={{
            width: `${o.size}px`,
            height: `${o.size}px`,
            border: o.size > 60 ? 'none' : `2px solid ${o.color}`,
          }}
        >
          <span class="font-bold" style={{ color: o.color, fontSize: o.size > 60 ? '16px' : '10px' }}>
            {o.size > 60 ? 'Node.js' : o.label}
          </span>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // 角色轮播
  const roles = ["前端开发工程师", "全栈开发者", "技术博主", "终身学习者"];
  let ri = 0;
  const rt = document.getElementById('role-text');
  setInterval(() => {
    ri = (ri + 1) % roles.length;
    if (rt) {
      rt.style.opacity = '0';
      rt.style.transform = 'translateY(-10px)';
      setTimeout(() => {
        rt.textContent = roles[ri];
        rt.style.opacity = '1';
        rt.style.transform = 'translateY(0)';
      }, 200);
    }
  }, 3000);

  // 3D 鼠标追踪
  const card = document.getElementById('hero-card');
  if (card) {
    const wrap = card.closest('.card-3d-wrap');
    wrap.addEventListener('mousemove', (e) => {
      const rect = wrap.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width - 0.5) * 20;
      const y = ((e.clientY - rect.top) / rect.height - 0.5) * -20;
      card.style.transform = `rotateX(${y}deg) rotateY(${x}deg)`;
    });
    wrap.addEventListener('mouseleave', () => {
      card.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });
  }
</script>
