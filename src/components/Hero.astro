---
// Hero 组件 - 首屏展示区域
const roles = ["前端开发者", "全栈工程师", "技术爱好者", "终身学习者"];
---

<section class="min-h-screen flex items-center justify-center relative overflow-hidden pt-16">
  <!-- 背景装饰 -->
  <div class="absolute inset-0 bg-gradient-to-br from-dark-950 via-dark-900 to-dark-950"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary-900/20 via-transparent to-transparent"></div>
  
  <!-- 动态背景粒子 -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-64 h-64 bg-primary-500/10 rounded-full blur-3xl -top-32 -left-32 animate-float"></div>
    <div class="absolute w-96 h-96 bg-primary-600/10 rounded-full blur-3xl -bottom-48 -right-48 animate-float" style="animation-delay: -3s;"></div>
  </div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <!-- 头像占位 -->
    <div class="mb-8">
      <div class="w-32 h-32 mx-auto rounded-full bg-gradient-to-br from-primary-400 to-primary-600 p-1">
        <div class="w-full h-full rounded-full bg-dark-800 flex items-center justify-center text-4xl font-bold text-primary-400">
          如
        </div>
      </div>
    </div>

    <!-- 名字 -->
    <h1 class="text-5xl md:text-7xl font-bold mb-4 bg-gradient-to-r from-white via-gray-200 to-gray-400 bg-clip-text text-transparent">
      如从
    </h1>

    <!-- 动态角色轮播 -->
    <div class="h-8 mb-6 overflow-hidden">
      <p class="text-xl md:text-2xl text-primary-400">
        <span id="role-text">前端开发者</span>
        <span class="animate-pulse">|</span>
      </p>
    </div>

    <!-- 简介 -->
    <p class="text-lg md:text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
      欢迎来到我的个人博客。我是一名热爱技术的开发者，专注于创造优秀的用户体验。
    </p>

    <!-- CTA 按钮 -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#projects" class="px-8 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-lg font-medium transition-all hover:scale-105 hover:shadow-lg hover:shadow-primary-500/25">
        查看项目
      </a>
      <a href="#contact" class="px-8 py-3 border border-dark-600 hover:border-primary-500 text-gray-300 hover:text-white rounded-lg font-medium transition-all hover:scale-105">
        联系我
      </a>
    </div>

    <!-- 滚动提示 -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<script>
  const roles = ["前端开发者", "全栈工程师", "技术爱好者", "终身学习者"];
  let currentIndex = 0;
  const roleText = document.getElementById('role-text');
  
  setInterval(() => {
    currentIndex = (currentIndex + 1) % roles.length;
    if (roleText) {
      roleText.style.opacity = '0';
      setTimeout(() => {
        roleText.textContent = roles[currentIndex];
        roleText.style.opacity = '1';
      }, 300);
    }
  }, 3000);
</script>
