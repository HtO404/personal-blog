---
// Influencer — 真·无限滚动 + CSS mask
const platforms = [
  { name: "GitHub", tag: "@yourname", stat1: "120+", stat2: "贡献", color: "#1e293b", stat1L: "Repos", stat2L: "Contributions" },
  { name: "掘金", tag: "@yourname", stat1: "5.2k", stat2: "粉丝", color: "#1d4ed8", stat1L: "Followers", stat2L: "Likes" },
  { name: "知乎", tag: "@yourname", stat1: "10+", stat2: "文章", color: "#0284c7", stat1L: "Articles", stat2L: "Views" },
  { name: "LeetCode", tag: "@yourname", stat1: "300+", stat2: "题解", color: "#d97706", stat1L: "Problems", stat2L: "Solutions" },
  { name: "博客", tag: "@yourname", stat1: "50+", stat2: "文章", color: "#047857", stat1L: "Posts", stat2L: "Reads" },
  { name: "StackOverflow", tag: "@yourname", stat1: "2k+", stat2: "声望", color: "#ea580c", stat1L: "Reputation", stat2L: "Answers" },
];
const items = [...platforms, ...platforms];
---

<section id="influencer" class="w-full relative z-10 py-36 md:py-48 overflow-hidden">
  <div class="px-4 lg:px-16 xl:px-32 2xl:px-44 mb-12 reveal">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Social</p>
    <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-slate-800">
      技术<span class="text-brand-500">影响力</span>
    </h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">在各大技术社区分享知识，与开发者一起成长。</p>
  </div>

  <!-- 无限滚动条 (同 qzq.at: mask + animate-scroll) -->
  <div class="scroller relative z-20 overflow-hidden scroll-mask">
    <div class="flex gap-4 scroll-infinite">
      {items.map((p, i) => (
        <div class="flex-shrink-0 w-[350px] max-w-full rounded-2xl border border-b-0 border-slate-200 p-6 text-white overflow-hidden relative"
             style={{ backgroundColor: p.color }}>
          <div class="opacity-10 text-8xl font-display font-bold absolute -right-4 -bottom-8 leading-none pointer-events-none select-none">{p.name[0]}</div>
          <p class="text-white/80 text-sm mb-1 font-medium">{p.name}</p>
          <p class="text-white/90 text-lg font-semibold mb-6">{p.tag}</p>
          <div class="flex gap-8">
            <div><p class="text-3xl font-bold">{p.stat1}</p><p class="text-white/70 text-sm">{p.stat1L}</p></div>
            <div><p class="text-3xl font-bold">{p.stat2}</p><p class="text-white/70 text-sm">{p.stat2L}</p></div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <p class="px-4 lg:px-16 xl:px-32 2xl:px-44 text-slate-500 text-lg mt-10 reveal max-w-xl">
    技术分享是学习成长的重要方式。通过博客、开源和社区互动持续积累影响力。
  </p>
</section>
