---
const projects = [
  {
    title: "个人博客系统", desc: "使用 Astro + React + Tailwind CSS 构建的现代化静态博客。支持 Markdown 写作和 Netlify 自动部署，Lighthouse 评分优秀。",
    tags: ["Astro", "React", "Tailwind"], highlights: ["Lighthouse 优秀", "自动部署", "SEO 友好"],
  },
  {
    title: "自动化测试框架", desc: "基于 uiautomator2 和 Selenium 的混合自动化测试框架，支持 Android / Web 并行执行，提升回归测试效率 70%。",
    tags: ["Python", "uiautomator2", "Selenium"], highlights: ["效率提升 70%", "跨平台", "并行执行"],
  },
  {
    title: "任务管理应用", desc: "基于 React + TypeScript 的任务管理应用，支持任务分类、优先级设置和 Local Storage 数据持久化。",
    tags: ["React", "TypeScript", "Local Storage"], highlights: ["数据持久化", "响应式设计", "组件化开发"],
  },
  {
    title: "数据可视化面板", desc: "使用 ECharts 和 Vue 构建的数据可视化仪表盘，支持多种图表类型和实时数据更新。",
    tags: ["Vue", "ECharts", "WebSocket"], highlights: ["实时更新", "多图表类型", "动态配置"],
  },
];
---

<section id="projects" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32">
  <div class="reveal mb-16">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Projects</p>
    <h2 class="font-fantasy text-5xl md:text-6xl lg:text-7xl font-bold text-slate-800">精选<span class="text-brand-500">项目</span></h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">代表技术能力和工程思维的项目作品。</p>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    {projects.map((p, i) => (
      <div class="card-white overflow-hidden reveal group" style={`transition-delay:${i*0.1}s`}>
        <div class="h-1.5 bg-gradient-to-r from-brand-400 to-brand-600"></div>
        <div class="p-6 md:p-8">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-slate-100 mb-4 group-hover:bg-brand-50 transition-colors">
            <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-brand-500 transition-colors">{p.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-4">{p.desc}</p>
          <div class="flex flex-wrap gap-2 mb-4">
            {p.highlights.map(h => (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-brand-50 text-brand-600 text-xs font-medium">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>{h}
              </span>
            ))}
          </div>
          <div class="flex flex-wrap gap-2">
            {p.tags.map(t => <span class="px-2 py-1 text-xs rounded-md bg-slate-100 text-slate-500 hover:bg-brand-50 hover:text-brand-600 transition-colors">{t}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ====== Contact ====== -->
