---
// Projects + Contact 合并在一个文件
const projects = [
  {
    title: "企业级管理后台",
    desc: "微前端架构的大型系统，支持多角色权限、数据可视化、报表导出。负责前端架构设计与性能优化。",
    tags: ["React", "TypeScript", "Ant Design", "ECharts"],
    color: "from-blue-600 to-indigo-700",
    highlights: ["微前端架构", "性能优化 60%", "代码覆盖率 90%"],
  },
  {
    title: "电商平台前端",
    desc: "完整电商解决方案，包含商品展示、购物车、订单管理、支付集成。采用 SSR 优化首屏加载。",
    tags: ["Next.js", "Tailwind", "Stripe", "Redis"],
    color: "from-emerald-600 to-teal-700",
    highlights: ["SSR 渲染", "PWA 支持", "首屏 < 1.5s"],
  },
  {
    title: "实时协作白板",
    desc: "支持 50+ 人实时协作的在线白板，WebSocket 同步延迟 < 100ms。用于远程会议与教学。",
    tags: ["Vue.js", "WebSocket", "Canvas", "Node.js"],
    color: "from-violet-600 to-purple-700",
    highlights: ["延迟 < 100ms", "50+ 人协作", "数据持久化"],
  },
  {
    title: "个人博客系统",
    desc: "Astro + React 构建的高性能静态博客。Lighthouse 评分 100，支持 Markdown 和 RSS。",
    tags: ["Astro", "React", "Tailwind"],
    color: "from-amber-600 to-orange-700",
    highlights: ["Lighthouse 100", "首屏 < 1s", "SEO 友好"],
  },
];
---

<section id="projects" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32">
  
  <div class="reveal mb-16">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Projects</p>
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-800">
      精选<span class="text-brand-500">项目</span>
    </h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">
      代表我的技术能力和工程思维的项目作品。
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    {projects.map((p, i) => (
      <div class={`group bg-white rounded-2xl shadow-sm shadow-slate-200/60 card-hover overflow-hidden reveal`} style={`transition-delay:${i*0.1}s`}>
        <!-- 项目色条 -->
        <div class={`h-2 bg-gradient-to-r ${p.color}`}></div>
        <div class="p-6 md:p-8">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-slate-100 mb-4 group-hover:bg-brand-50 transition-colors">
            <svg class="w-6 h-6 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-brand-500 transition-colors">{p.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-4">{p.desc}</p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {p.highlights.map(h => (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-brand-50 text-brand-600 text-xs">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {h}
              </span>
            ))}
          </div>
          <div class="flex flex-wrap gap-2">
            {p.tags.map(t => (
              <span class="px-2 py-1 text-xs rounded-md bg-slate-100 text-slate-600">{t}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ====== Contact ====== -->
<section id="contact" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32">
  
  <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm shadow-slate-200/60 reveal">
    <div class="text-center mb-8">
      <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Contact</p>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-800 mb-4">
        联系<span class="text-brand-500">我</span>
      </h2>
      <p class="text-slate-500 text-lg max-w-md mx-auto">
        欢迎交流技术、合作项目或任何有趣的想法。
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 max-w-2xl mx-auto">
      <a href="mailto:email@example.com" class="flex flex-col items-center gap-3 p-6 rounded-xl hover:bg-brand-50 transition-colors group">
        <div class="w-14 h-14 rounded-2xl bg-brand-100 flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <p class="text-slate-800 font-semibold">邮箱</p>
        <p class="text-slate-400 text-sm">email@example.com</p>
      </a>
      <a href="https://github.com" target="_blank" class="flex flex-col items-center gap-3 p-6 rounded-xl hover:bg-brand-50 transition-colors group">
        <div class="w-14 h-14 rounded-2xl bg-brand-100 flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-brand-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </div>
        <p class="text-slate-800 font-semibold">GitHub</p>
        <p class="text-slate-400 text-sm">@yourname</p>
      </a>
      <div class="flex flex-col items-center gap-3 p-6 rounded-xl hover:bg-brand-50 transition-colors group">
        <div class="w-14 h-14 rounded-2xl bg-brand-100 flex items-center justify-center group-hover:scale-110 transition-transform">
          <svg class="w-6 h-6 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </div>
        <p class="text-slate-800 font-semibold">位置</p>
        <p class="text-slate-400 text-sm">中国·北京</p>
      </div>
    </div>
  </div>
</section>
