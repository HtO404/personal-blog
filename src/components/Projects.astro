---
// Projects 组件 - 项目展示
const projects = [
  {
    title: "个人博客系统",
    description: "使用 Astro + React + Tailwind CSS 构建的现代化静态博客，支持 Markdown 写作和自动部署。",
    tags: ["Astro", "React", "Tailwind"],
    link: "#",
    github: "#"
  },
  {
    title: "任务管理应用",
    description: "基于 React 的任务管理应用，支持任务分类、优先级设置和数据持久化。",
    tags: ["React", "TypeScript", "Local Storage"],
    link: "#",
    github: "#"
  },
  {
    title: "数据可视化面板",
    description: "使用 ECharts 和 Vue 构建的数据可视化仪表盘，支持多种图表类型和实时数据更新。",
    tags: ["Vue", "ECharts", "WebSocket"],
    link: "#",
    github: "#"
  }
];
---

<section id="projects" class="py-20 px-4 bg-dark-900/50">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      项目<span class="text-primary-400">作品</span>
    </h2>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <div class="group bg-dark-800/50 rounded-xl border border-dark-700 hover:border-primary-500/50 transition-all hover:shadow-lg hover:shadow-primary-500/5 overflow-hidden">
          <!-- 项目图片占位 -->
          <div class="aspect-video bg-gradient-to-br from-dark-700 to-dark-800 flex items-center justify-center">
            <svg class="w-12 h-12 text-dark-600 group-hover:text-primary-500/50 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-primary-400 transition-colors">
              {project.title}
            </h3>
            <p class="text-gray-400 text-sm mb-4 line-clamp-2">
              {project.description}
            </p>
            
            <!-- 标签 -->
            <div class="flex flex-wrap gap-2 mb-4">
              {project.tags.map((tag) => (
                <span class="px-2 py-0.5 bg-dark-700 text-gray-400 rounded text-xs">{tag}</span>
              ))}
            </div>
            
            <!-- 链接 -->
            <div class="flex gap-3">
              <a href={project.link} class="flex items-center gap-1 text-sm text-gray-400 hover:text-primary-400 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                预览
              </a>
              <a href={project.github} class="flex items-center gap-1 text-sm text-gray-400 hover:text-primary-400 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                源码
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    <!-- 更多项目提示 -->
    <div class="text-center mt-8">
      <a href="#" class="text-primary-400 hover:text-primary-300 transition-colors text-sm">
        查看更多项目 →
      </a>
    </div>
  </div>
</section>
