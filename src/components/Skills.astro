---
// Skills — card-white 对角渐变 + card-dark 深层阴影
const categories = [
  {
    name: "前端",
    skills: [
      { name: "React / Next.js", level: 95, color: "#61DAFB" },
      { name: "TypeScript", level: 90, color: "#3178C6" },
      { name: "Vue.js", level: 85, color: "#4FC08D" },
      { name: "HTML / CSS / Tailwind", level: 95, color: "#06B6D4" },
      { name: "JavaScript", level: 92, color: "#F7DF1E" },
    ]
  },
  {
    name: "后端",
    skills: [
      { name: "Node.js", level: 80, color: "#339933" },
      { name: "Python", level: 75, color: "#3776AB" },
      { name: "GraphQL", level: 72, color: "#E10098" },
      { name: "PostgreSQL", level: 70, color: "#336791" },
    ]
  },
  {
    name: "工具",
    skills: [
      { name: "Git / GitHub", level: 90, color: "#F05032" },
      { name: "Docker", level: 70, color: "#2496ED" },
      { name: "Webpack / Vite", level: 85, color: "#8DD6F9" },
      { name: "Jest / Cypress", level: 78, color: "#C21325" },
    ]
  },
];
---

<section id="skills" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32">

  <div class="reveal mb-16">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Skills</p>
    <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-slate-800">
      技术<span class="text-brand-500">能力</span>
    </h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">持续学习积累的全面技术栈。</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 auto-rows-min">
    {categories.map(cat => (
      <div class="card-white p-6 reveal">
        <h3 class="text-lg font-bold text-slate-800 mb-5 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-brand-500"></span>
          {cat.name}
        </h3>
        <div class="space-y-4">
          {cat.skills.map(s => (
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-slate-600 font-medium">{s.name}</span>
                <span class="text-slate-400 font-mono">{s.level}%</span>
              </div>
              <div class="h-1.5 bg-slate-200/60 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-700 ease-out"
                     style={`width:${s.level}%;background:${s.color};box-shadow:0 0 6px ${s.color}60;`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- 持续学习 card-dark -->
  <div class="mt-12 card-dark p-8 reveal flex flex-col md:flex-row items-center gap-6">
    <div class="w-16 h-16 rounded-2xl bg-brand-500/20 flex items-center justify-center flex-shrink-0">
      <svg class="w-8 h-8 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    </div>
    <div>
      <h3 class="text-xl font-bold text-white mb-2">持续学习</h3>
      <p class="text-gray-300">正在深入研究 <span class="text-brand-400 font-medium">WebAssembly</span>、<span class="text-brand-400 font-medium">Rust</span> 和 <span class="text-brand-400 font-medium">大模型应用开发</span>，保持技术视野前沿。</p>
    </div>
  </div>
</section>
