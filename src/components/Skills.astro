---
// Skills — 真实数据: python, c, 测试工具等
const categories = [
  {
    name: "编程语言",
    skills: [
      { name: "Python", level: 85, color: "#3776AB" },
      { name: "C", level: 70, color: "#555555" },
      { name: "JavaScript / TypeScript", level: 90, color: "#F7DF1E" },
    ]
  },
  {
    name: "自动化测试",
    skills: [
      { name: "uiautomator2", level: 80, color: "#34D399" },
      { name: "Selenium", level: 75, color: "#43B02A" },
      { name: "接口测试 (Apifox/Postman)", level: 85, color: "#FF6C37" },
    ]
  },
  {
    name: "测试工具链",
    skills: [
      { name: "JIRA / TPAD", level: 80, color: "#0052CC" },
      { name: "JMeter", level: 70, color: "#D33833" },
      { name: "DBeaver (SQL)", level: 65, color: "#336791" },
      { name: "日志分析", level: 75, color: "#6B7280" },
    ]
  },
  {
    name: "平台 & 协议",
    skills: [
      { name: "Linux 基础", level: 65, color: "#FCC624" },
      { name: "多平台测试", level: 80, color: "#34D399" },
      { name: "MAVLink 协议", level: 60, color: "#F97316" },
      { name: "串口调试", level: 65, color: "#6366F1" },
    ]
  },
];

const tools = ["Xmind", "Postman", "Apifox", "JMeter", "DBeaver", "Git", "VS Code", "PyCharm"];
---

<section id="skills" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32">

  <div class="reveal mb-16">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Skills</p>
    <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-slate-800">
      技术<span class="text-brand-500">能力</span>
    </h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">测试开发 + 前端开发的全方位技术栈积累。</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 auto-rows-min">
    {categories.map(cat => (
      <div class="card-white p-6 reveal">
        <h3 class="text-lg font-bold text-slate-800 mb-5 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-brand-500"></span>
          {cat.name}
        </h3>
        <div class="space-y-4">
          {cat.skills.map(s => (
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-slate-600 font-medium">{s.name}</span>
                <span class="text-slate-400 font-mono">{s.level}%</span>
              </div>
              <div class="h-1.5 bg-slate-200/60 rounded-full overflow-hidden">
                <div class="h-full rounded-full transition-all duration-700 ease-out"
                     style={`width:${s.level}%;background:${s.color};box-shadow:0 0 6px ${s.color}60;`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- 工具标签云 -->
  <div class="mt-12 reveal">
    <div class="text-center mb-6">
      <h3 class="text-lg font-semibold text-slate-800 mb-2">常用工具</h3>
    </div>
    <div class="flex flex-wrap justify-center gap-3">
      {tools.map(t => (
        <span class="px-4 py-2 rounded-xl bg-white border border-slate-200 text-slate-500 hover:text-brand-500 hover:border-brand-300 hover:bg-brand-50 transition-all cursor-default shadow-sm">{t}</span>
      ))}
    </div>
  </div>
</section>
