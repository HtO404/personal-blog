---
// Skills 组件 - 技能展示
const skills = [
  { name: "JavaScript / TypeScript", level: 90, category: "前端" },
  { name: "React / Vue", level: 85, category: "前端" },
  { name: "HTML / CSS / Tailwind", level: 90, category: "前端" },
  { name: "Node.js", level: 75, category: "后端" },
  { name: "Python", level: 70, category: "后端" },
  { name: "Git / GitHub", level: 85, category: "工具" },
  { name: "Docker", level: 60, category: "工具" },
  { name: "SQL / MongoDB", level: 65, category: "数据库" },
];

const categories = [...new Set(skills.map(s => s.category))];
---

<section id="skills" class="py-20 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      技术<span class="text-primary-400">技能</span>
    </h2>
    
    <div class="grid md:grid-cols-2 gap-8">
      {categories.map((category) => (
        <div class="bg-dark-800/50 rounded-xl p-6 border border-dark-700">
          <h3 class="text-lg font-semibold text-primary-400 mb-4">{category}</h3>
          <div class="space-y-4">
            {skills.filter(s => s.category === category).map((skill) => (
              <div>
                <div class="flex justify-between text-sm mb-1">
                  <span class="text-gray-300">{skill.name}</span>
                  <span class="text-gray-500">{skill.level}%</span>
                </div>
                <div class="h-2 bg-dark-700 rounded-full overflow-hidden">
                  <div 
                    class="h-full bg-gradient-to-r from-primary-500 to-primary-400 rounded-full transition-all duration-1000"
                    style={`width: ${skill.level}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
