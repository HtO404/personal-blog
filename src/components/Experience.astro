---
// Experience 组件 - 工作经历时间线
const experiences = [
  {
    company: "某科技公司",
    role: "前端开发工程师",
    period: "2022 - 至今",
    description: "负责公司核心产品的前端架构设计与开发，带领团队完成多个重要项目。",
    highlights: ["React/Vue 项目开发", "性能优化", "团队协作"]
  },
  {
    company: "某互联网公司",
    role: "前端开发实习生",
    period: "2021 - 2022",
    description: "参与公司电商平台的前端开发，学习并实践了现代前端开发流程。",
    highlights: ["组件开发", "页面重构", "单元测试"]
  }
];
---

<section id="experience" class="py-20 px-4 bg-dark-900/50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      工作<span class="text-primary-400">经历</span>
    </h2>
    
    <div class="relative">
      <!-- 时间线 -->
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-dark-700 md:-translate-x-1/2"></div>
      
      <!-- 经历卡片 -->
      <div class="space-y-12">
        {experiences.map((exp, index) => (
          <div class={`relative flex flex-col md:flex-row gap-8 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- 时间点 -->
            <div class="absolute left-0 md:left-1/2 w-3 h-3 bg-primary-500 rounded-full -translate-x-1/2 mt-1.5 ring-4 ring-dark-950"></div>
            
            <!-- 内容 -->
            <div class={`ml-6 md:ml-0 md:w-1/2 ${index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
              <div class="bg-dark-800/50 rounded-xl p-6 border border-dark-700 hover:border-primary-500/50 transition-all hover:shadow-lg hover:shadow-primary-500/5">
                <span class="text-primary-400 text-sm font-medium">{exp.period}</span>
                <h3 class="text-xl font-bold text-white mt-1">{exp.role}</h3>
                <p class="text-gray-400 mt-1">{exp.company}</p>
                <p class="text-gray-300 mt-3 text-sm leading-relaxed">{exp.description}</p>
                <div class={`flex flex-wrap gap-2 mt-4 ${index % 2 === 0 ? 'md:justify-end' : ''}`}>
                  {exp.highlights.map((h) => (
                    <span class="px-2 py-1 bg-dark-700 text-gray-300 rounded text-xs">{h}</span>
                  ))}
                </div>
              </div>
            </div>
            
            <!-- 占位 -->
            <div class="hidden md:block md:w-1/2"></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
