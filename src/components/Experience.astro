---
// Experience — card-white + card-dark 对角渐变
const jobs = [
  {
    company: "某知名科技公司", role: "高级前端开发工程师",
    period: "2022.06 – 至今", location: "北京",
    desc: "负责核心产品前端架构，主导性能优化与组件库建设。使用 React + TypeScript 重构旧系统，提升页面加载速度 60%，并建立前端工程化规范。",
    skills: ["React", "TypeScript", "Next.js", "GraphQL", "Tailwind"],
  },
  {
    company: "某互联网公司", role: "前端开发工程师",
    period: "2021.03 – 2022.05", location: "上海",
    desc: "参与电商平台前端开发，独立负责商品详情页重构，转化率提升 15%。开发可视化数据大屏，支持实时数据展示与交互。",
    skills: ["Vue.js", "JavaScript", "ECharts", "Element UI", "Webpack"],
  },
  {
    company: "某创业公司", role: "前端开发实习生",
    period: "2020.07 – 2021.02", location: "杭州",
    desc: "加入早期团队参与产品从 0 到 1 开发，包括 CI/CD、代码审查、单元测试等工程实践。",
    skills: ["HTML/CSS", "JavaScript", "jQuery", "Bootstrap", "Git"],
  },
];
---

<section id="experience" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32 lg:mt-64">

  <div class="reveal mb-16">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Experience</p>
    <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-slate-800">
      工作<span class="text-brand-500">经历</span>
    </h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">在不同规模公司积累的全方位工程能力。</p>
  </div>

  <div class="relative">
    <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-slate-300 md:-translate-x-1/2"></div>

    <div class="space-y-16">
      {jobs.map((job, i) => (
        <div class={`relative flex flex-col md:flex-row gap-8 ${i % 2 === 0 ? '' : 'md:flex-row-reverse'}`}>
          <div class="absolute left-0 md:left-1/2 w-3 h-3 bg-brand-500 rounded-full -translate-x-[4px] md:-translate-x-1.5 mt-1.5 ring-4 ring-gray-50"></div>

          <div class={`hidden md:block md:w-1/2 ${i % 2 === 0 ? 'md:text-right md:pr-12' : 'md:text-left md:pl-12'}`}>
            <span class="text-brand-500 font-mono text-sm font-semibold">{job.period}</span>
            <p class="text-slate-400 text-sm">{job.location}</p>
          </div>

          <div class={`ml-6 md:ml-0 md:w-1/2 ${i % 2 === 0 ? 'md:pl-12' : 'md:pr-12'}`}>
            <div class="card-white p-6 group reveal">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <h3 class="text-xl font-bold text-slate-800 group-hover:text-brand-500 transition-colors">{job.role}</h3>
              </div>
              <p class="text-brand-500 font-semibold text-sm mb-1">{job.company}</p>
              <div class="md:hidden text-brand-500 font-mono text-xs mb-3">{job.period} · {job.location}</div>
              <p class="text-slate-500 text-sm leading-relaxed mb-4">{job.desc}</p>
              <div class="flex flex-wrap gap-2">
                {job.skills.map(s => (
                  <span class="px-3 py-1 text-xs rounded-full bg-slate-100 text-slate-600 border border-slate-200">{s}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
