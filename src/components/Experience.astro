---
// Experience — 真实资料注入: 本初子午 + 博彦科技
const jobs = [
  {
    company: "本初子午", role: "测试开发实习生",
    period: "2025.01 – 2025.06", location: "武汉", type: "实习",
    desc: "参与 SaaS + App + Web 产品的全流程测试，覆盖功能测试、接口测试、自动化测试。",
    achievements: [
      "参与 PRD 评审，从测试角度分析需求的可测试性和测试策略",
      "编写自动化测试脚本，使用 uiautomator2、Selenium 提升回归效率",
      "使用 Apifox、Postman 执行接口测试，保障 API 稳定性",
      "使用 TPAD 提交缺陷跟踪，跨部门协调开发与运维定位缺陷"
    ],
    skills: ["Python", "uiautomator2", "Selenium", "Apifox", "Postman", "TPAD"]
  },
  {
    company: "博彦科技", role: "测试实习生",
    period: "2024.09 – 2024.12", location: "武汉", type: "实习",
    desc: "负责 HP Smart 打印机产品测试，覆盖 Android / iOS / Windows / macOS 多平台。",
    achievements: [
      "搭建测试环境，配置模拟器和真机测试账号",
      "负责 HP 打印机核心功能测试，覆盖 4 个平台",
      "编写执行测试用例，验证打印机配置、打印等核心功能稳定性",
      "编写学习手册和测试用例，同步新版本回归测试效率"
    ],
    skills: ["Android", "iOS", "Windows", "macOS", "测试用例设计", "JIRA"]
  },
];
---

<section id="experience" class="w-full px-4 lg:px-16 xl:px-32 2xl:px-44 relative z-10 my-24 lg:my-32 lg:mt-64">

  <div class="reveal mb-16">
    <p class="text-brand-500 text-sm font-medium tracking-wider uppercase mb-3">Experience</p>
    <h2 class="font-display text-5xl md:text-6xl lg:text-7xl font-bold text-slate-800">
      工作<span class="text-brand-500">经历</span>
    </h2>
    <p class="text-slate-500 text-lg mt-4 max-w-xl">在不同企业积累的测试开发与工程实践能力。</p>
  </div>

  <div class="relative">
    <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-slate-300 md:-translate-x-1/2"></div>
    <div class="space-y-16">
      {jobs.map((job, i) => (
        <div class={`relative flex flex-col md:flex-row gap-8 ${i % 2 === 0 ? '' : 'md:flex-row-reverse'}`}>
          <div class="absolute left-0 md:left-1/2 w-3 h-3 bg-brand-500 rounded-full -translate-x-[4px] md:-translate-x-1.5 mt-1.5 ring-4 ring-gray-50"></div>
          <div class={`hidden md:block md:w-1/2 ${i % 2 === 0 ? 'md:text-right md:pr-12' : 'md:text-left md:pl-12'}`}>
            <span class="text-brand-500 font-mono text-sm font-semibold">{job.period}</span>
            <p class="text-slate-400 text-sm">{job.location}</p>
          </div>
          <div class={`ml-6 md:ml-0 md:w-1/2 ${i % 2 === 0 ? 'md:pl-12' : 'md:pr-12'}`}>
            <div class="card-white p-6 group reveal">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <h3 class="text-xl font-bold text-slate-800 group-hover:text-brand-500 transition-colors">{job.role}</h3>
                <span class="px-3 py-1 text-xs rounded-full bg-brand-50 text-brand-600 border border-brand-200">{job.type}</span>
              </div>
              <p class="text-brand-500 font-semibold text-sm mb-1">{job.company}</p>
              <div class="md:hidden text-brand-500 font-mono text-xs mb-3">{job.period} · {job.location}</div>
              <p class="text-slate-500 text-sm leading-relaxed mb-4">{job.desc}</p>
              <div class="mb-3">
                <ul class="space-y-1.5">
                  {job.achievements.map(a => (
                    <li class="flex items-start gap-2 text-sm text-slate-500">
                      <svg class="w-4 h-4 text-brand-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      <span>{a}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="flex flex-wrap gap-2">
                {job.skills.map(s => <span class="px-3 py-1 text-xs rounded-full bg-slate-100 text-slate-600 border border-slate-200">{s}</span>)}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- 教育背景 card-dark -->
  <div class="mt-12 card-dark p-8 reveal flex flex-col md:flex-row items-center gap-6">
    <div class="w-16 h-16 rounded-2xl bg-brand-500/20 flex items-center justify-center flex-shrink-0">
      <svg class="w-8 h-8 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
    </div>
    <div>
      <h3 class="text-xl font-bold text-white mb-2">教育背景</h3>
      <p class="text-gray-300"><span class="text-brand-400 font-medium">武汉城市学院</span> · 软件工程 · 本科 · 2026届</p>
      <p class="text-gray-400 text-sm mt-1">专业前5% · 国家奖学金获得者 · 专业一等奖学金</p>
    </div>
  </div>
</section>
