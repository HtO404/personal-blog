---
interface Props { title: string; description?: string; }
const { title, description = "如从 - 测试开发工程师 | 前端开发" } = Astro.props;
const navLinks = [
  { label: "关于", id: "home" },
  { label: "经历", id: "experience" },
  { label: "技能", id: "skills" },
  { label: "项目", id: "projects" },
  { label: "联系", id: "contact" },
];
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Coda:wght@400;800&display=swap" rel="stylesheet" />
  <title>{title}</title>
  <style is:global>
    body {
      background: #f9fafb;
      font-family: 'Inter', system-ui, sans-serif;
    }

    /* ====== 主容器 ====== */
    .main-wrap {
      background:
        /* noise 纹理 — 模仿 qzq.at 的 noise.webp */
        url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E"),
        /* dot 点阵 */
        radial-gradient(circle at 1px 1px, rgba(0,0,0,0.06) 1px, transparent 1px);
      background-size: 160px 160px, 20px 20px;
      /* 之上叠加 radial 渐变 */
      position: relative;
    }
    .main-wrap::before {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      background: radial-gradient(circle at 100% 50%, #d1d3d6, #fcfcfd);
      mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.3), transparent 70%);
      pointer-events: none;
    }
    .main-wrap > * {
      position: relative;
      z-index: 1;
    }

    /* ====== 三个核心卡片类 ====== */
    .card-light {
      background: linear-gradient(to right bottom, #fcfcfd 20%, #d0d2d7 150%);
      box-shadow: rgba(0, 0, 0, 0.1) 0px 25px 50px -12px;
      border-radius: 24px;
      position: relative;
    }
    .card-white {
      background: linear-gradient(to right bottom, #fcfcfd 20%, #f2f2f3 150%);
      box-shadow: rgba(0, 0, 0, 0.1) 0px 25px 50px -12px;
      border-radius: 12px;
      position: relative;
    }
    .card-dark {
      background: linear-gradient(to right bottom, #334155 20%, #1d2530 150%);
      box-shadow: rgba(0, 0, 0, 0.1) 20px 113px 140px -30px;
      border-radius: 12px;
      position: relative;
    }

    /* 装饰色块 — 仿 qzq.at bg-orange-400 blob */
    .card-light::after, .card-white::after {
      content: '';
      position: absolute;
      width: 48px;
      height: 48px;
      background: #F97316;
      border-radius: 50%;
      bottom: -12px;
      left: -12px;
      opacity: 0.15;
      filter: blur(12px);
      pointer-events: none;
    }

    /* ====== Orbit 动画 ====== */
    @keyframes orbit {
      0%   { transform: rotate(0deg) translateY(calc(var(--radius) * 1px)) rotate(0deg); }
      100% { transform: rotate(1turn) translateY(calc(var(--radius) * 1px)) rotate(-1turn); }
    }
    .orbit-anim {
      animation: orbit calc(var(--duration, 10) * 1s) linear infinite;
      animation-delay: calc(var(--delay, 0) * 1ms);
    }

    /* ====== Orbit 引导圆环 ====== */
    .orbit-ring {
      position: absolute;
      border-radius: 50%;
      border: 1px solid rgba(0,0,0,0.06);
      pointer-events: none;
    }

    /* ====== 脉冲动画 ====== */
    @keyframes pulse-glow {
      0%   { transform: scale(0.98); box-shadow: rgba(251, 146, 60, 0.7) 0 0 0 0; }
      70%  { transform: scale(1);    box-shadow: rgba(251, 146, 60, 0) 0 0 0 90px; }
      100% { transform: scale(0.98); box-shadow: rgba(251, 146, 60, 0) 0 0 0 0; }
    }
    .pulse-anim { animation: pulse-glow 2s infinite; }

    /* ====== 无限滚动 ====== */
    @keyframes scroll-x {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .scroll-infinite { animation: scroll-x 25s linear infinite; }
    .scroll-infinite:hover { animation-play-state: paused; }

    /* ====== 滚动视差 ====== */
    .reveal {
      opacity: 0;
      transform: translateY(50px) scale(0.95);
      transition: opacity 0.9s cubic-bezier(0.5, 0, 0, 1), transform 0.9s cubic-bezier(0.5, 0, 0, 1);
    }
    .reveal.active { opacity: 1; transform: translateY(0) scale(1); }
    .reveal.half { opacity: 0.5; transform: translateY(30px) scale(0.95); }

    /* ====== 悬浮 ====== */
    .card-white, .card-light, .card-dark {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card-white:hover, .card-light:hover {
      transform: translateY(-4px);
      box-shadow: rgba(0, 0, 0, 0.15) 0px 30px 60px -12px;
    }
    .card-dark:hover {
      transform: translateY(-4px);
      box-shadow: rgba(0, 0, 0, 0.2) 20px 120px 150px -30px;
    }

    /* ====== 滚动条遮罩 ====== */
    .scroll-mask {
      mask-image: linear-gradient(90deg, transparent, white 20%, white 80%, transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, white 20%, white 80%, transparent);
    }

    /* ====== 3D 卡片 ====== */
    .card-3d-wrap { perspective: 600px; }
    .card-3d { transform-style: preserve-3d; transition: transform 0.2s ease; }

    /* ====== 链接下划线装饰 ====== */
    .link-underline {
      position: relative;
      display: inline-block;
    }
    .link-underline::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(to right, #F97316, #EA580C);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }
    .link-underline:hover::after {
      transform: scaleX(1);
    }
  </style>
</head>
<body class="min-h-screen text-slate-700 antialiased">

  <!-- 导航 -->
  <header class="fixed top-0 left-0 right-0 z-50 px-4 lg:px-16 xl:px-32 2xl:px-44 h-[65px] flex items-center justify-between backdrop-blur-[2px] bg-gradient-to-b from-gray-50 to-gray-50/0 border-b border-gray-300/10">
    <a href="#home" class="text-lg font-bold text-slate-700 hover:text-brand-500 transition-colors">如从</a>
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a href={`#${link.id}`} class="text-sm text-slate-500 hover:text-brand-500 transition-colors">{link.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-4">
      <a href="https://github.com" target="_blank" class="text-slate-400 hover:text-slate-700 transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg></a>
      <a href="mailto:17398206513@163.com" class="text-slate-400 hover:text-slate-700 transition-colors"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></a>
    </div>
  </header>

  <div class="main-wrap w-full overflow-hidden text-slate-700">
    <slot />
  </div>

  <footer class="px-4 lg:px-16 xl:px-32 2xl:px-44 py-12 border-t border-slate-200 bg-white">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-slate-400 text-sm">&copy; {new Date().getFullYear()} 如从 · Built with Astro & Tailwind</p>
      <div class="flex items-center gap-6">
        <a href="https://github.com" target="_blank" class="text-slate-400 hover:text-brand-500 transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg></a>
      </div>
    </div>
  </footer>

  <script>
    // 滚动视差
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const el = entry.target;
        if (entry.isIntersecting) {
          const ratio = entry.intersectionRatio;
          if (ratio >= 0.8) { el.classList.add('active'); el.classList.remove('half'); }
          else if (ratio >= 0.3) { el.classList.add('half'); el.classList.remove('active'); }
        } else { el.classList.remove('active', 'half'); }
      });
    }, { threshold: [0, 0.3, 0.8, 1] });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  </script>
</body>
</html>
